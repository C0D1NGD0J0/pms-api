#!/usr/bin/env sh
set -e

echo "Running pre-push checks..."

# Security audit
echo "🔒 Running security audit..."
npm audit --audit-level=critical --omit=dev || {
  echo "❌ Critical vulnerabilities found in production dependencies. Run 'npm audit' for details."
  exit 1
}

# Format check
echo "🎨 Checking code formatting..."
npm run prettier:check || {
  echo "❌ Code formatting check failed. Run 'npx prettier --write' to fix."
  exit 1
}

# Lint
echo "📝 Running ESLint..."
npm run lint || {
  echo "❌ Lint errors found. Please fix before pushing."
  exit 1
}

# TypeScript type check
echo "🔎 Running TypeScript check..."
npx tsc --noEmit -p tsconfig.build.json || {
  echo "❌ TypeScript errors found. Please fix type errors before pushing."
  exit 1
}

# Unit tests (only files changed vs main)
echo "🧪 Running affected tests..."
npx jest --changedSince=origin/main --passWithNoTests || {
  echo "❌ Tests failed. Please fix the failing tests before pushing."
  exit 1
}

echo "✅ All pre-push checks passed!"