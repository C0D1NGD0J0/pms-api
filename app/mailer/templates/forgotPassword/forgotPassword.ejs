<table role="presentation" width="100%">
  <tr>
    <td class="content">
      <h2>Reset Your Password</h2>
      <p>Hi <%= fullname %>,</p>
      <p>
        We received a request to reset the password on your PropertyDesk account. Click the button below to choose a new password.
      </p>
      <p style="font-size: 13px; color: #64748b;">
        This link expires in <strong>1 hour</strong>. If you didn't request a password reset, no action is needed — your account is safe.
      </p>
    </td>
  </tr>
  <tr>
    <td class="cta">
      <%- include("../shared/html/_button", { url: resetUrl, label: "Reset Password" }) %>
      <p class="fallback-link">
        Button not working? Copy and paste this link into your browser:<br />
        <%= resetUrl %>
      </p>
    </td>
  </tr>
</table>
