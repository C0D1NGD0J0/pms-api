<table role="presentation" width="100%">
  <tr>
    <td class="content">
      <h2>Your Resident Portal is Ready</h2>
      <p>Hi <%= inviteeName %>,</p>
      <p>
        <strong><%= inviterName %></strong> at <strong><%= companyName %></strong> has set up your resident account on PropertyDesk.
      </p>
      <p>
        Your portal gives you 24/7 access to submit maintenance requests, pay rent online, view lease documents, and communicate with your property management team.
      </p>

      <% if (customMessage) { %>
      <div class="message-quote">
        "<%= customMessage %>"
      </div>
      <% } %>

      <p style="font-size: 13px; color: #64748b;">
        This invitation expires on <strong><%= new Date(expiresAt).toLocaleDateString() %></strong>. If you weren't expecting this, you can safely ignore this email.
      </p>
    </td>
  </tr>
  <tr>
    <td class="cta">
      <%- include("../shared/html/_button", { url: invitationUrl, label: "Activate My Account" }) %>
      <p class="fallback-link">
        Button not working? Copy and paste this link into your browser:<br />
        <%= invitationUrl %>
      </p>
    </td>
  </tr>
</table>
