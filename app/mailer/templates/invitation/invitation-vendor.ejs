<table role="presentation" width="100%">
  <tr>
    <td class="content">
      <h2>You're Invited to Join Our Vendor Network</h2>
      <p>Hi <%= inviteeName %>,</p>
      <p>
        <strong><%= inviterName %></strong> at <strong><%= companyName %></strong> has invited you to join their vendor network on PropertyDesk.
      </p>
      <p>
        As a vendor partner, you'll receive work orders, submit invoices, and get paid efficiently — all through a single platform.
      </p>

      <% if (customMessage) { %>
      <div class="message-quote">
        "<%= customMessage %>"
      </div>
      <% } %>

      <p style="font-size: 13px; color: #64748b;">
        This invitation expires on <strong><%= new Date(expiresAt).toLocaleDateString() %></strong>. If you weren't expecting this, you can safely ignore this email.
      </p>
    </td>
  </tr>
  <tr>
    <td class="cta">
      <%- include("../shared/html/_button", { url: invitationUrl, label: "Accept Invitation" }) %>
      <p class="fallback-link">
        Button not working? Copy and paste this link into your browser:<br />
        <%= invitationUrl %>
      </p>
    </td>
  </tr>
</table>
