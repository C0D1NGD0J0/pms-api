<table role="presentation" width="100%">
  <tr>
    <td class="content">
      <h2>Your Lease is Now Active</h2>
      <p>Hi <%= tenantName %>,</p>
      <p>
        Your lease agreement for <strong><%= propertyAddress %></strong> has been fully executed and is now active.
      </p>
    </td>
  </tr>

  <tr>
    <td class="content" style="padding-top: 0;">
      <div class="detail-card">
        <h3 style="margin-top: 0;">Lease Details</h3>
        <table class="detail-table">
          <tr>
            <td class="detail-label">Lease Number</td>
            <td class="detail-value"><%= leaseNumber %></td>
          </tr>
          <tr>
            <td class="detail-label">Property</td>
            <td class="detail-value"><%= propertyAddress %></td>
          </tr>
          <% if (unitNumber) { %>
          <tr>
            <td class="detail-label">Unit</td>
            <td class="detail-value"><%= unitNumber %></td>
          </tr>
          <% } %>
          <tr>
            <td class="detail-label">Start Date</td>
            <td class="detail-value"><%= new Date(startDate).toLocaleDateString() %></td>
          </tr>
          <tr>
            <td class="detail-label">End Date</td>
            <td class="detail-value"><%= new Date(endDate).toLocaleDateString() %></td>
          </tr>
          <tr>
            <td class="detail-label">Monthly Rent</td>
            <td class="detail-value" style="color: #16a34a; font-weight: 600;"><%= rentAmount %></td>
          </tr>
        </table>
      </div>
    </td>
  </tr>

  <tr>
    <td class="cta">
      <%- include("../shared/html/_button", { url: leaseUrl, label: "View Your Lease" }) %>
      <p class="fallback-link">
        Button not working? Copy and paste this link into your browser:<br />
        <%= leaseUrl %>
      </p>
    </td>
  </tr>

  <tr>
    <td class="content">
      <h3>Next Steps</h3>
      <ul>
        <li><strong>Move-in Date:</strong> <%= new Date(startDate).toLocaleDateString() %></li>
        <li><strong>First Payment Due:</strong> <%= firstPaymentDate %></li>
        <li><strong>Security Deposit:</strong> <%= securityDepositInfo %></li>
        <li><strong>Keys &amp; Access:</strong> Contact your property manager to arrange key pickup</li>
      </ul>

      <div class="notice-box info">
        Complete your move-in inspection within <strong>7 days of move-in</strong> and report any pre-existing issues to your property manager.
      </div>

      <p style="font-size: 14px; color: #64748b; margin-top: 20px;">
        Questions about your lease or move-in? Reach your property manager at
        <a href="mailto:<%= propertyManagerEmail %>"><%= propertyManagerEmail %></a> or <%= propertyManagerPhone %>.
      </p>
    </td>
  </tr>
</table>
