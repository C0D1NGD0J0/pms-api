<table role="presentation" width="100%">
  <tr>
    <td class="content">
      <h2>Your Lease Has Been Updated</h2>
      <p>Hi <%= tenantName %>,</p>
      <p>
        Administrative details on your lease for <strong><%= propertyAddress %></strong>
        have been updated by your property manager.
      </p>
      <p>
        Core terms such as your rent amount, lease dates, and property assignment remain unchanged.
        The update may include changes to payment method, late fee policy, or other administrative settings.
      </p>
    </td>
  </tr>

  <tr>
    <td class="content" style="padding-top: 0;">
      <div class="detail-card">
        <h3 style="margin-top: 0;">Lease Details</h3>
        <table class="detail-table">
          <tr>
            <td class="detail-label">Lease Number</td>
            <td class="detail-value"><%= leaseNumber %></td>
          </tr>
          <tr>
            <td class="detail-label">Property</td>
            <td class="detail-value"><%= propertyAddress %></td>
          </tr>
          <tr>
            <td class="detail-label">Updated By</td>
            <td class="detail-value"><%= updatedBy %></td>
          </tr>
        </table>
      </div>
    </td>
  </tr>

  <tr>
    <td class="cta">
      <%- include("../shared/html/_button", { url: leaseUrl, label: "View Your Lease" }) %>
      <p class="fallback-link">
        Button not working? Copy and paste this link into your browser:<br />
        <%= leaseUrl %>
      </p>
    </td>
  </tr>

  <tr>
    <td class="content">
      <div class="notice-box info">
        If you have questions about these changes, please contact your property manager directly.
      </div>
    </td>
  </tr>
</table>
