<table role="presentation" width="100%">
  <tr>
    <td class="content">
      <% if (notificationStage === 'final_reminder') { %>
        <h2>Final Notice: Lease Expiring in <%= daysRemaining %> Days</h2>
        <p>Hi <%= tenantName %>,</p>
        <p style="color: #991b1b; font-weight: 600;">
          Your lease for <strong><%= propertyAddress %></strong> expires in <strong><%= daysRemaining %> days</strong>. Immediate action is required.
        </p>
      <% } else if (notificationStage === 'renewal_ready') { %>
        <h2>Your Lease Renewal is Ready</h2>
        <p>Hi <%= tenantName %>,</p>
        <p>
          Your renewal lease agreement for <strong><%= propertyAddress %></strong> is ready for your review and signature.
        </p>
      <% } else if (notificationStage === 'auto_renewal_signature') { %>
        <h2>Action Required: Sign Your Renewal Agreement</h2>
        <p>Hi <%= tenantName %>,</p>
        <p>
          Your lease at <strong><%= propertyAddress %></strong> is set to auto-renew in <strong><%= daysRemaining %> days</strong>. Please sign the renewal agreement to confirm.
        </p>
      <% } else if (isAutoRenewing) { %>
        <h2>Your Lease Will Auto-Renew</h2>
        <p>Hi <%= tenantName %>,</p>
        <p>
          Your lease at <strong><%= propertyAddress %></strong> is set to automatically renew for <strong><%= renewalTermMonths %> months</strong>.
        </p>
      <% } else { %>
        <h2>Your Lease is Ending Soon</h2>
        <p>Hi <%= tenantName %>,</p>
        <p>
          Your lease at <strong><%= propertyAddress %></strong> is approaching its end date. Please review your options below.
        </p>
      <% } %>
    </td>
  </tr>

  <tr>
    <td class="content" style="padding-top: 0;">
      <div class="detail-card <%= isAutoRenewing ? '' : 'warning' %>">
        <h3 style="margin-top: 0;"><%= isAutoRenewing ? 'Auto-Renewal Details' : 'Lease End Details' %></h3>
        <table class="detail-table">
          <tr>
            <td class="detail-label">Lease Number</td>
            <td class="detail-value"><%= leaseNumber %></td>
          </tr>
          <tr>
            <td class="detail-label">Property</td>
            <td class="detail-value"><%= propertyAddress %></td>
          </tr>
          <% if (unitNumber) { %>
          <tr>
            <td class="detail-label">Unit</td>
            <td class="detail-value"><%= unitNumber %></td>
          </tr>
          <% } %>
          <tr>
            <td class="detail-label">Lease End Date</td>
            <td class="detail-value" style="color: #dc2626; font-weight: 600;"><%= new Date(endDate).toLocaleDateString() %></td>
          </tr>
          <tr>
            <td class="detail-label">Days Remaining</td>
            <td class="detail-value"><%= daysRemaining %> days</td>
          </tr>
        </table>
      </div>
    </td>
  </tr>

  <tr>
    <td class="content">
      <% if (isAutoRenewing) { %>
      <div class="option-card option-renew">
        <h4>Your Lease Will Automatically Renew</h4>
        <p style="margin: 8px 0; color: #555;">
          No action required. Your lease renews for <strong><%= renewalTermMonths %> months</strong> under the current terms.
        </p>
        <% if (renewalTerms) { %>
        <p style="margin: 8px 0; color: #555; font-style: italic; font-size: 14px;"><%= renewalTerms %></p>
        <% } %>
      </div>
      <div class="notice-box warning">
        <strong>Planning to move out instead?</strong> You must provide <strong><%= noticePeriod %> days</strong> written notice by <strong><%= new Date(noticeDeadline).toLocaleDateString() %></strong>.
      </div>
      <% } else { %>
      <h3>Your Options</h3>

      <div class="option-card option-renew">
        <h4>Option 1 — Renew Your Lease</h4>
        <p style="margin: 8px 0; color: #555;">
          We'd love to have you stay. Contact us to discuss renewal terms and updated rates.
        </p>
        <% if (renewalUrl) { %>
        <p style="margin: 10px 0 0 0;">
          <a href="<%= renewalUrl %>" style="color: #16a34a; font-weight: 600;">Express Interest in Renewal &rarr;</a>
        </p>
        <% } %>
      </div>

      <div class="option-card option-mtm">
        <h4>Option 2 — Month-to-Month</h4>
        <p style="margin: 8px 0; color: #555;">
          <% if (monthToMonthAvailable) { %>
          You may be eligible to continue on a month-to-month basis. <%= monthToMonthTerms ? monthToMonthTerms : 'Contact us for details.' %>
          <% } else { %>
          Month-to-month arrangements are not available for this property. Please choose renewal or move-out.
          <% } %>
        </p>
      </div>

      <div class="option-card option-move">
        <h4>Option 3 — Move Out</h4>
        <p style="margin: 8px 0; color: #555;">
          If you plan to move out, provide written notice by <strong><%= new Date(noticeDeadline).toLocaleDateString() %></strong> as required by your lease.
        </p>
      </div>
      <% } %>

      <div class="notice-box danger" style="margin-top: 20px;">
        <strong>Notice Deadline:</strong> Written notice is required <strong><%= noticePeriod %> days</strong> in advance if you plan to move out. Deadline: <strong><%= new Date(noticeDeadline).toLocaleDateString() %></strong>.
      </div>

      <ul style="margin-top: 16px; font-size: 14px; color: #475569;">
        <li><strong>Respond by:</strong> <%= new Date(responseDeadline).toLocaleDateString() %></li>
        <li><strong>Contact:</strong> <a href="mailto:<%= propertyManagerEmail %>"><%= propertyManagerEmail %></a> or <%= propertyManagerPhone %></li>
        <li><strong>State clearly:</strong> whether you are renewing, going month-to-month, or moving out</li>
      </ul>

      <% if (renewalTerms) { %>
      <div class="notice-box info">
        <strong>Renewal Terms:</strong><br /><%= renewalTerms %>
      </div>
      <% } %>

      <p style="font-size: 13px; color: #64748b; margin-top: 20px; border-top: 1px solid #e2e8f0; padding-top: 16px;">
        Property Manager: <%= propertyManagerName %><br />
        Email: <%= propertyManagerEmail %><br />
        Phone: <%= propertyManagerPhone %><br />
        Office Hours: <%= officeHours || 'Monday–Friday, 9am–5pm' %>
      </p>
    </td>
  </tr>
</table>
