<table role="presentation" width="100%">
  <tr>
    <td class="content">
      <h2>Lease Termination Notice</h2>
      <p>Hi <%= tenantName %>,</p>
      <p>
        This notice confirms that your lease agreement for <strong><%= propertyAddress %></strong> has been terminated.
      </p>
    </td>
  </tr>

  <tr>
    <td class="content" style="padding-top: 0;">
      <div class="detail-card warning">
        <h3 style="margin-top: 0;">Termination Details</h3>
        <table class="detail-table">
          <tr>
            <td class="detail-label">Lease Number</td>
            <td class="detail-value"><%= leaseNumber %></td>
          </tr>
          <tr>
            <td class="detail-label">Property</td>
            <td class="detail-value"><%= propertyAddress %></td>
          </tr>
          <% if (unitNumber) { %>
          <tr>
            <td class="detail-label">Unit</td>
            <td class="detail-value"><%= unitNumber %></td>
          </tr>
          <% } %>
          <tr>
            <td class="detail-label">Termination Date</td>
            <td class="detail-value" style="color: #dc2626;"><%= new Date(terminationDate).toLocaleDateString() %></td>
          </tr>
          <% if (moveOutDate) { %>
          <tr>
            <td class="detail-label">Move-Out Date</td>
            <td class="detail-value"><%= new Date(moveOutDate).toLocaleDateString() %></td>
          </tr>
          <% } %>
          <tr>
            <td class="detail-label">Reason</td>
            <td class="detail-value"><%= terminationReason %></td>
          </tr>
        </table>
      </div>
    </td>
  </tr>

  <tr>
    <td class="cta">
      <%- include("../shared/html/_button", { url: leaseUrl, label: "View Lease Details", colorClass: "btn-muted" }) %>
      <p class="fallback-link">
        Button not working? Copy and paste this link into your browser:<br />
        <%= leaseUrl %>
      </p>
    </td>
  </tr>

  <tr>
    <td class="content">
      <h3>Move-Out Checklist</h3>
      <ul>
        <li><strong>Vacate by:</strong> <%= moveOutDate ? new Date(moveOutDate).toLocaleDateString() : new Date(terminationDate).toLocaleDateString() %></li>
        <li><strong>Property Condition:</strong> Return the property in the same condition as move-in, excluding normal wear and tear</li>
        <li><strong>Final Inspection:</strong> Schedule a walk-through with your property manager before your move-out date</li>
        <li><strong>Keys &amp; Access:</strong> Return all keys, access cards, and remotes</li>
        <li><strong>Forwarding Address:</strong> Provide your new address for security deposit processing</li>
        <li><strong>Utilities:</strong> Cancel or transfer all utility accounts effective on your move-out date</li>
      </ul>

      <div class="notice-box info">
        Your security deposit will be processed in accordance with applicable state law. You will receive an itemized statement and any refund due within the legally required timeframe after move-out.
      </div>

      <% if (notes) { %>
      <div class="notice-box" style="background-color: #f8fafc; border-color: #e2e8f0; color: #475569;">
        <strong>Additional Notes:</strong><br />
        <%= notes %>
      </div>
      <% } %>

      <p style="font-size: 14px; color: #64748b; margin-top: 20px;">
        Questions about the termination or move-out process? Contact your property manager immediately at
        <a href="mailto:<%= propertyManagerEmail %>"><%= propertyManagerEmail %></a> or <%= propertyManagerPhone %>.
      </p>

      <p style="font-size: 12px; color: #94a3b8; margin-top: 20px; border-top: 1px solid #e2e8f0; padding-top: 16px;">
        This is an official notice. Please retain this email for your records.
      </p>
    </td>
  </tr>
</table>
