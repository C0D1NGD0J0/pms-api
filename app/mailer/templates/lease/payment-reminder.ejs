<table role="presentation" width="100%">
  <tr>
    <td class="content">
      <h2>Rent Payment Reminder</h2>
      <p>Hi <%= tenantName %>,</p>
      <p>
        Your rent payment for <strong><%= propertyAddress %></strong> is due soon.
      </p>
    </td>
  </tr>

  <tr>
    <td class="content" style="padding-top: 0;">
      <div class="detail-card">
        <h3 style="margin-top: 0;">Payment Details</h3>
        <table class="detail-table">
          <tr>
            <td class="detail-label">Property</td>
            <td class="detail-value"><%= propertyAddress %></td>
          </tr>
          <% if (unitNumber) { %>
          <tr>
            <td class="detail-label">Unit</td>
            <td class="detail-value"><%= unitNumber %></td>
          </tr>
          <% } %>
          <tr>
            <td class="detail-label">Amount Due</td>
            <td class="detail-value" style="font-size: 20px; font-weight: 700; color: #062f4f;"><%= amountDue %></td>
          </tr>
          <tr>
            <td class="detail-label">Due Date</td>
            <td class="detail-value" style="color: #dc2626; font-weight: 600;"><%= new Date(dueDate).toLocaleDateString() %></td>
          </tr>
          <tr>
            <td class="detail-label">Days Until Due</td>
            <td class="detail-value"><%= daysUntilDue %> days</td>
          </tr>
        </table>
      </div>
    </td>
  </tr>

  <% if (paymentUrl) { %>
  <tr>
    <td class="cta">
      <%- include("../shared/html/_button", { url: paymentUrl, label: "Pay Now", colorClass: "btn-success" }) %>
      <p class="fallback-link">
        Button not working? Copy and paste this link into your browser:<br />
        <%= paymentUrl %>
      </p>
    </td>
  </tr>
  <% } %>

  <tr>
    <td class="content">
      <h3>Payment Methods</h3>
      <ul>
        <% if (paymentMethods && paymentMethods.includes('online')) { %>
        <li><strong>Online:</strong> Log in to your resident portal and pay securely</li>
        <% } %>
        <% if (paymentMethods && paymentMethods.includes('check')) { %>
        <li><strong>Check:</strong> Mail to <%= mailAddress %></li>
        <% } %>
        <% if (paymentMethods && paymentMethods.includes('bank')) { %>
        <li><strong>Bank Transfer:</strong> <%= bankDetails %></li>
        <% } %>
        <% if (paymentMethods && paymentMethods.includes('cash')) { %>
        <li><strong>In Person:</strong> Visit the property management office</li>
        <% } %>
      </ul>

      <div class="notice-box warning">
        <strong>Late Fee:</strong> A fee of <strong><%= lateFeeAmount %></strong> will be charged if payment is not received by <strong><%= new Date(lateFeeDate).toLocaleDateString() %></strong>.
      </div>

      <% if (currentBalance && currentBalance !== amountDue) { %>
      <div class="notice-box danger">
        <strong>Outstanding Balance:</strong> You have an outstanding balance of <strong><%= currentBalance %></strong>. Please contact your property manager to discuss payment arrangements.
      </div>
      <% } %>

      <p style="font-size: 14px; color: #64748b; margin-top: 20px;">
        If you've already made this payment, please disregard this reminder. For questions or payment arrangements, contact your property manager at
        <a href="mailto:<%= propertyManagerEmail %>"><%= propertyManagerEmail %></a> or <%= propertyManagerPhone %>.
      </p>
    </td>
  </tr>
</table>
