<table role="presentation" width="100%">
  <tr>
    <td class="content">
      <h2>Maintenance Charge Added to Your Account</h2>
      <p>
        A maintenance charge has been added to your account for work completed at your property.
        You have until <strong><%= new Date(dueDate).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) %></strong> to pay manually —
        after that date, the amount will be automatically debited from your payment method on file.
      </p>
    </td>
  </tr>

  <tr>
    <td class="content" style="padding-top: 0;">
      <div class="detail-card warning">
        <h3 style="margin-top: 0;">Charge Details</h3>
        <table class="detail-table">
          <tr>
            <td class="detail-label">Reference #</td>
            <td class="detail-value"><%= mruid %></td>
          </tr>
          <% if (jobTitle) { %>
          <tr>
            <td class="detail-label">Job</td>
            <td class="detail-value"><%= jobTitle %></td>
          </tr>
          <% } %>
          <tr>
            <td class="detail-label">Amount Due</td>
            <td class="detail-value" style="font-size: 18px; font-weight: 700; color: #dc2626;">
              $<%= (amountInCents / 100).toFixed(2) %> <%= (currency || 'USD').toUpperCase() %>
            </td>
          </tr>
          <tr>
            <td class="detail-label">Due Date</td>
            <td class="detail-value">
              <%= new Date(dueDate).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) %>
            </td>
          </tr>
        </table>
      </div>
    </td>
  </tr>

  <tr>
    <td class="content" style="text-align: center; padding: 24px 32px;">
      <a href="<%= process.env.APP_URL %>/tenants/<%= cuid %>/<%= pytuid %>/payments"
         style="display: inline-block; background-color: #124e66; color: #ffffff; text-decoration: none; padding: 12px 28px; border-radius: 6px; font-weight: 600; font-size: 15px;">
        Pay Now
      </a>
    </td>
  </tr>

  <tr>
    <td class="content">
      <p style="font-size: 13px; color: #64748b;">
        If you do not pay by the due date, the amount will be automatically charged to your payment method on file.
        Questions? Contact your property manager directly.
      </p>
    </td>
  </tr>
</table>
