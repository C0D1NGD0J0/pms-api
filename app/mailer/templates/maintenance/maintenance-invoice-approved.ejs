<table role="presentation" width="100%">
  <tr>
    <td class="content">
      <h2>Invoice Approved</h2>
      <p>
        Your invoice for the maintenance job below has been <strong style="color: #16a34a;">approved</strong>. Payment will be processed according to the agreed payment terms.
      </p>
    </td>
  </tr>

  <tr>
    <td class="content" style="padding-top: 0;">
      <div class="detail-card success">
        <h3 style="margin-top: 0;">Approval Details</h3>
        <table class="detail-table">
          <tr>
            <td class="detail-label">Reference #</td>
            <td class="detail-value"><%= request.mruid %></td>
          </tr>
          <tr>
            <td class="detail-label">Job</td>
            <td class="detail-value"><%= request.title %></td>
          </tr>
          <% if (request.invoice) { %>
          <tr>
            <td class="detail-label">Approved Amount</td>
            <td class="detail-value" style="font-size: 18px; font-weight: 700; color: #16a34a;">
              $<%= (request.invoice.amount / 100).toFixed(2) %> <%= request.invoice.currency.toUpperCase() %>
            </td>
          </tr>
          <tr>
            <td class="detail-label">Approved By</td>
            <td class="detail-value"><%= approvedBy.firstName || approvedBy.email %></td>
          </tr>
          <tr>
            <td class="detail-label">Approved On</td>
            <td class="detail-value"><%= new Date().toLocaleDateString() %></td>
          </tr>
          <% } %>
        </table>
      </div>
    </td>
  </tr>

  <tr>
    <td class="content">
      <p style="font-size: 14px; color: #64748b;">
        For questions about payment timing, contact the property manager directly.
      </p>
    </td>
  </tr>
</table>
