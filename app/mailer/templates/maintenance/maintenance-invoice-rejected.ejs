<table role="presentation" width="100%">
  <tr>
    <td class="content">
      <h2>Invoice Rejected — Resubmission Required</h2>
      <p>
        Your invoice for the maintenance job below has been <strong style="color: #dc2626;">rejected</strong>. Please review the reason and submit a corrected invoice.
      </p>
    </td>
  </tr>

  <tr>
    <td class="content" style="padding-top: 0;">
      <div class="detail-card danger">
        <h3 style="margin-top: 0;">Rejection Details</h3>
        <table class="detail-table">
          <tr>
            <td class="detail-label">Reference #</td>
            <td class="detail-value"><%= request.mruid %></td>
          </tr>
          <tr>
            <td class="detail-label">Job</td>
            <td class="detail-value"><%= request.title %></td>
          </tr>
          <tr>
            <td class="detail-label">Rejected By</td>
            <td class="detail-value"><%= rejectedBy.firstName || rejectedBy.email %></td>
          </tr>
          <tr>
            <td class="detail-label">Reason</td>
            <td class="detail-value" style="color: #991b1b;"><%= rejectionReason %></td>
          </tr>
        </table>
      </div>
    </td>
  </tr>

  <tr>
    <td class="content">
      <p>Log in to the portal to submit a revised invoice addressing the reason above.</p>
      <p style="font-size: 14px; color: #64748b;">
        If you believe this rejection is in error, contact <strong><%= rejectedBy.firstName || rejectedBy.email %></strong><% if (rejectedBy.email) { %> at <a href="mailto:<%= rejectedBy.email %>"><%= rejectedBy.email %></a><% } %>.
      </p>
    </td>
  </tr>
</table>
