<table width="100%">
  <tr>
    <td class="content">
      <h3>Invoice Rejected — Resubmission Required</h3>
      <p>
        Your invoice for the maintenance job below has been <strong>rejected</strong> by the property manager.
        Please review the reason and resubmit a corrected invoice.
      </p>
    </td>
  </tr>

  <tr>
    <td class="content" style="background-color: #f8d7da; padding: 20px; border-left: 4px solid #dc3545; border-radius: 4px; margin-bottom: 16px;">
      <h4 style="margin-top: 0; color: #721c24;">Invoice Rejected</h4>
      <table width="100%" style="border-collapse: collapse;">
        <tr>
          <td style="padding: 6px 0; color: #666; width: 40%;">Reference #:</td>
          <td style="padding: 6px 0; font-weight: 600;"><%= request.mruid %></td>
        </tr>
        <tr>
          <td style="padding: 6px 0; color: #666;">Job:</td>
          <td style="padding: 6px 0; font-weight: 600;"><%= request.title %></td>
        </tr>
        <tr>
          <td style="padding: 6px 0; color: #666;">Rejected By:</td>
          <td style="padding: 6px 0;"><%= rejectedBy.firstName || rejectedBy.email %></td>
        </tr>
        <tr>
          <td style="padding: 6px 0; color: #666; vertical-align: top;">Reason:</td>
          <td style="padding: 6px 0; font-weight: 600; color: #721c24;"><%= rejectionReason %></td>
        </tr>
      </table>
    </td>
  </tr>

  <tr>
    <td class="content">
      <p>Please log in to the portal to submit a revised invoice addressing the reason above.</p>
      <p style="color: #666; font-size: 14px;">
        If you believe this rejection is in error, contact <%= rejectedBy.firstName || rejectedBy.email %><% if (rejectedBy.email) { %> at <%= rejectedBy.email %><% } %>.
      </p>
    </td>
  </tr>
</table>
