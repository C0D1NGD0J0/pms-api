<table role="presentation" width="100%">
  <tr>
    <td class="content">
      <h2>Invoice Submitted — Review Required</h2>
      <p>
        A vendor has submitted an invoice for the maintenance request below. Please review and approve or reject it at your earliest convenience.
      </p>
    </td>
  </tr>

  <tr>
    <td class="content" style="padding-top: 0;">
      <div class="detail-card">
        <h3 style="margin-top: 0;">Invoice Summary</h3>
        <table class="detail-table">
          <tr>
            <td class="detail-label">Reference #</td>
            <td class="detail-value"><%= request.mruid %></td>
          </tr>
          <tr>
            <td class="detail-label">Job Title</td>
            <td class="detail-value"><%= request.title %></td>
          </tr>
          <tr>
            <td class="detail-label">Invoice Amount</td>
            <td class="detail-value" style="font-size: 18px; font-weight: 700; color: #062f4f;">
              $<%= (amount / 100).toFixed(2) %> <%= (request.invoice && request.invoice.currency) ? request.invoice.currency.toUpperCase() : 'USD' %>
            </td>
          </tr>
          <tr>
            <td class="detail-label">Submitted</td>
            <td class="detail-value"><%= new Date().toLocaleDateString() %></td>
          </tr>
          <% if (request.invoice && request.invoice.description) { %>
          <tr>
            <td class="detail-label">Description</td>
            <td class="detail-value"><%= request.invoice.description %></td>
          </tr>
          <% } %>
        </table>
      </div>
    </td>
  </tr>

  <tr>
    <td class="content">
      <p>Log in to the portal to <strong>approve or reject</strong> this invoice. Approving will record it as a maintenance expense.</p>
    </td>
  </tr>
</table>
