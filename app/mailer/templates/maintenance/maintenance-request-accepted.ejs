<table role="presentation" width="100%">
  <tr>
    <td class="content">
      <h2>Your Request is Being Handled</h2>
      <p>Hi <%= tenant && (tenant.firstName || tenant.email) ? (tenant.firstName || tenant.email) : 'Resident' %>,</p>
      <p>
        Good news — a vendor has <strong>accepted</strong> your maintenance request and will be in touch to schedule the work.
      </p>
    </td>
  </tr>

  <tr>
    <td class="content" style="padding-top: 0;">
      <div class="detail-card">
        <h3 style="margin-top: 0;">Request Details</h3>
        <table class="detail-table">
          <tr>
            <td class="detail-label">Reference #</td>
            <td class="detail-value"><%= request.mruid %></td>
          </tr>
          <tr>
            <td class="detail-label">Title</td>
            <td class="detail-value"><%= request.title %></td>
          </tr>
          <tr>
            <td class="detail-label">Category</td>
            <td class="detail-value"><%= request.category.replace(/_/g, ' ') %></td>
          </tr>
          <tr>
            <td class="detail-label">Priority</td>
            <td class="detail-value" style="font-weight: 600; text-transform: uppercase;"><%= request.priority %></td>
          </tr>
          <% if (request.assignedTechnician && request.assignedTechnician.name) { %>
          <tr>
            <td class="detail-label">Technician</td>
            <td class="detail-value"><%= request.assignedTechnician.name %><% if (request.assignedTechnician.phone) { %> — <%= request.assignedTechnician.phone %><% } %></td>
          </tr>
          <% } %>
          <% if (request.scheduledDate) { %>
          <tr>
            <td class="detail-label">Scheduled Date</td>
            <td class="detail-value"><%= new Date(request.scheduledDate).toLocaleDateString() %></td>
          </tr>
          <% } %>
        </table>
      </div>
    </td>
  </tr>

  <tr>
    <td class="content">
      <p>You will be contacted to confirm the schedule. Please ensure access is available at the agreed time.</p>
      <p style="font-size: 14px; color: #64748b;">
        Log in to the resident portal to track the status of your request.
      </p>
    </td>
  </tr>
</table>
