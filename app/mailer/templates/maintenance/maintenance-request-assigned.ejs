<table role="presentation" width="100%">
  <tr>
    <td class="content">
      <h2>New Job Assignment</h2>
      <p>Hi <%= vendor.firstName || vendor.email %>,</p>
      <p>
        <strong><%= assignedBy.firstName || assignedBy.email %></strong> has assigned you a maintenance request. Please review the details below and <strong>accept or decline within 24 hours</strong>.
      </p>
    </td>
  </tr>

  <tr>
    <td class="content" style="padding-top: 0;">
      <div class="detail-card">
        <h3 style="margin-top: 0;">Job Details</h3>
        <table class="detail-table">
          <tr>
            <td class="detail-label">Reference #</td>
            <td class="detail-value"><%= request.mruid %></td>
          </tr>
          <tr>
            <td class="detail-label">Title</td>
            <td class="detail-value"><%= request.title %></td>
          </tr>
          <tr>
            <td class="detail-label">Description</td>
            <td class="detail-value"><%= request.description %></td>
          </tr>
          <tr>
            <td class="detail-label">Category</td>
            <td class="detail-value"><%= request.category.replace(/_/g, ' ') %></td>
          </tr>
          <tr>
            <td class="detail-label">Priority</td>
            <td class="detail-value" style="font-weight: 600; text-transform: uppercase;"><%= request.priority %></td>
          </tr>
          <tr>
            <td class="detail-label">Property Entry</td>
            <td class="detail-value"><%= request.permissionToEnter ? 'Permission granted' : 'Must coordinate with resident' %></td>
          </tr>
          <% if (request.scheduledDate) { %>
          <tr>
            <td class="detail-label">Scheduled Date</td>
            <td class="detail-value"><%= new Date(request.scheduledDate).toLocaleDateString() %></td>
          </tr>
          <% } %>
          <% if (request.estimatedCost) { %>
          <tr>
            <td class="detail-label">Estimated Cost</td>
            <td class="detail-value">$<%= (request.estimatedCost / 100).toFixed(2) %></td>
          </tr>
          <% } %>
          <% if (request.preferredDate) { %>
          <tr>
            <td class="detail-label">Resident Preferred Date</td>
            <td class="detail-value"><%= new Date(request.preferredDate).toLocaleDateString() %></td>
          </tr>
          <% } %>
          <% if (request.availabilityWindows && request.availabilityWindows.length > 0) { %>
          <tr>
            <td class="detail-label">Resident Availability</td>
            <td class="detail-value"><%= request.availabilityWindows.join(', ').replace(/_/g, ' ') %></td>
          </tr>
          <% } %>
        </table>
      </div>
    </td>
  </tr>

  <tr>
    <td class="content">
      <p>
        Log in to the portal to <strong>accept or decline</strong> this assignment. If you decline, the request will be reassigned to another vendor.
      </p>
      <p style="font-size: 14px; color: #64748b;">
        Questions? Contact <strong><%= assignedBy.firstName || assignedBy.email %></strong><% if (assignedBy.email) { %> at <a href="mailto:<%= assignedBy.email %>"><%= assignedBy.email %></a><% } %>.
      </p>
    </td>
  </tr>
</table>
