<table width="100%">
  <tr>
    <td class="content">
      <h3>Hello <%= vendor.firstName || vendor.email %>,</h3>
      <p>
        A maintenance request has been assigned to you by <strong><%= assignedBy.firstName || assignedBy.email %></strong>.
        Please review the details below and <strong>accept or decline within 24 hours</strong>.
      </p>
    </td>
  </tr>

  <tr>
    <td class="content" style="background-color: #d1ecf1; padding: 20px; border-left: 4px solid #17a2b8; border-radius: 4px; margin-bottom: 16px;">
      <h4 style="margin-top: 0; color: #0c5460;">Job Details</h4>
      <table width="100%" style="border-collapse: collapse;">
        <tr>
          <td style="padding: 6px 0; color: #666; width: 40%;">Reference #:</td>
          <td style="padding: 6px 0; font-weight: 600;"><%= request.mruid %></td>
        </tr>
        <tr>
          <td style="padding: 6px 0; color: #666;">Title:</td>
          <td style="padding: 6px 0; font-weight: 600;"><%= request.title %></td>
        </tr>
        <tr>
          <td style="padding: 6px 0; color: #666;">Description:</td>
          <td style="padding: 6px 0;"><%= request.description %></td>
        </tr>
        <tr>
          <td style="padding: 6px 0; color: #666;">Category:</td>
          <td style="padding: 6px 0;"><%= request.category.replace(/_/g, ' ') %></td>
        </tr>
        <tr>
          <td style="padding: 6px 0; color: #666;">Priority:</td>
          <td style="padding: 6px 0; font-weight: 600;"><%= request.priority.toUpperCase() %></td>
        </tr>
        <tr>
          <td style="padding: 6px 0; color: #666;">Entry Permission:</td>
          <td style="padding: 6px 0;"><%= request.permissionToEnter ? 'Granted' : 'Must coordinate with tenant' %></td>
        </tr>
        <% if (request.scheduledDate) { %>
        <tr>
          <td style="padding: 6px 0; color: #666;">Scheduled Date:</td>
          <td style="padding: 6px 0; font-weight: 600;"><%= new Date(request.scheduledDate).toLocaleDateString() %></td>
        </tr>
        <% } %>
        <% if (request.estimatedCost) { %>
        <tr>
          <td style="padding: 6px 0; color: #666;">Estimated Cost:</td>
          <td style="padding: 6px 0;">$<%= (request.estimatedCost / 100).toFixed(2) %></td>
        </tr>
        <% } %>
        <% if (request.preferredDate) { %>
        <tr>
          <td style="padding: 6px 0; color: #666;">Tenant Preferred Date:</td>
          <td style="padding: 6px 0;"><%= new Date(request.preferredDate).toLocaleDateString() %></td>
        </tr>
        <% } %>
        <% if (request.availabilityWindows && request.availabilityWindows.length > 0) { %>
        <tr>
          <td style="padding: 6px 0; color: #666;">Tenant Availability:</td>
          <td style="padding: 6px 0;"><%= request.availabilityWindows.join(', ').replace(/_/g, ' ') %></td>
        </tr>
        <% } %>
      </table>
    </td>
  </tr>

  <tr>
    <td class="content">
      <p>Please log in to the portal to <strong>accept or decline</strong> this assignment. If you decline, the request will be reassigned to another vendor.</p>
      <p style="color: #666; font-size: 14px;">Questions? Contact <strong><%= assignedBy.firstName || assignedBy.email %></strong><% if (assignedBy.email) { %> at <%= assignedBy.email %><% } %>.</p>
    </td>
  </tr>
</table>
