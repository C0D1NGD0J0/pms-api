<table role="presentation" width="100%">
  <tr>
    <td class="content">
      <h2>Vendor Declined — Reassignment Required</h2>
      <p>
        A vendor has declined the maintenance request below. The request has been returned to <strong>Open</strong> status and requires reassignment.
      </p>
    </td>
  </tr>

  <tr>
    <td class="content" style="padding-top: 0;">
      <div class="detail-card warning">
        <h3 style="margin-top: 0;">Action Required</h3>
        <table class="detail-table">
          <tr>
            <td class="detail-label">Reference #</td>
            <td class="detail-value"><%= request.mruid %></td>
          </tr>
          <tr>
            <td class="detail-label">Title</td>
            <td class="detail-value"><%= request.title %></td>
          </tr>
          <tr>
            <td class="detail-label">Priority</td>
            <td class="detail-value"><%= request.priority %></td>
          </tr>
          <tr>
            <td class="detail-label">Status</td>
            <td class="detail-value" style="color: #0369a1;">Open — awaiting reassignment</td>
          </tr>
          <% if (reason) { %>
          <tr>
            <td class="detail-label">Vendor Reason</td>
            <td class="detail-value" style="font-style: italic;">"<%= reason %>"</td>
          </tr>
          <% } %>
        </table>
      </div>
    </td>
  </tr>

  <tr>
    <td class="content">
      <p>Log in to the portal to assign a new vendor to this request.</p>
    </td>
  </tr>
</table>
