<table role="presentation" width="100%">
  <tr>
    <td class="content">
      <h2>Work Order Rejected — Revision Required</h2>
      <p>
        Your work order for maintenance request <strong><%= request.mruid %></strong> has been <strong style="color: #dc2626;">rejected</strong>. Please review the feedback below and resubmit.
      </p>
    </td>
  </tr>

  <tr>
    <td class="content" style="padding-top: 0;">
      <div class="detail-card danger">
        <h3 style="margin-top: 0;">Rejection Details</h3>
        <table class="detail-table">
          <tr>
            <td class="detail-label">Request #</td>
            <td class="detail-value"><%= request.mruid %></td>
          </tr>
          <tr>
            <td class="detail-label">Title</td>
            <td class="detail-value"><%= request.title %></td>
          </tr>
          <tr>
            <td class="detail-label">Rejected By</td>
            <td class="detail-value"><%= rejectedBy.firstName || rejectedBy.email %></td>
          </tr>
          <tr>
            <td class="detail-label">Reason</td>
            <td class="detail-value" style="color: #991b1b;"><%= rejectionReason %></td>
          </tr>
        </table>
      </div>
    </td>
  </tr>

  <tr>
    <td class="content">
      <p>
        Please revise your work order to address the feedback above and resubmit via the portal. You can resubmit as long as the request remains in <strong>Assigned</strong> status.
      </p>
    </td>
  </tr>
</table>
