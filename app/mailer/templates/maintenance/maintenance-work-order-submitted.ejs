<table role="presentation" width="100%">
  <tr>
    <td class="content">
      <h2>Work Order Submitted — Review Required</h2>
      <p>
        A vendor has submitted a work order for maintenance request <strong><%= request.mruid %></strong>. Your approval is required before they can begin work.
      </p>
    </td>
  </tr>

  <tr>
    <td class="content" style="padding-top: 0;">
      <div class="detail-card warning">
        <h3 style="margin-top: 0;">Work Order Details</h3>
        <table class="detail-table">
          <tr>
            <td class="detail-label">Request #</td>
            <td class="detail-value"><%= request.mruid %></td>
          </tr>
          <tr>
            <td class="detail-label">Title</td>
            <td class="detail-value"><%= request.title %></td>
          </tr>
          <tr>
            <td class="detail-label">Estimated Cost</td>
            <td class="detail-value" style="font-weight: 700;">$<%= (workOrder.estimatedCostInCents / 100).toFixed(2) %></td>
          </tr>
          <tr>
            <td class="detail-label">Scope of Work</td>
            <td class="detail-value"><%= workOrder.scope %></td>
          </tr>
          <% if (workOrder.notes) { %>
          <tr>
            <td class="detail-label">Notes</td>
            <td class="detail-value"><%= workOrder.notes %></td>
          </tr>
          <% } %>
        </table>
      </div>
    </td>
  </tr>

  <% if (workOrder.lineItems && workOrder.lineItems.length > 0) { %>
  <tr>
    <td class="content">
      <h3>Line Items</h3>
      <table role="presentation" width="100%" style="border-collapse: collapse; font-size: 14px;">
        <thead>
          <tr style="background-color: #f8fafc;">
            <th style="padding: 8px 10px; text-align: left; border-bottom: 2px solid #e2e8f0; color: #475569;">Description</th>
            <th style="padding: 8px 10px; text-align: right; border-bottom: 2px solid #e2e8f0; color: #475569;">Qty</th>
            <th style="padding: 8px 10px; text-align: right; border-bottom: 2px solid #e2e8f0; color: #475569;">Unit Price</th>
            <th style="padding: 8px 10px; text-align: right; border-bottom: 2px solid #e2e8f0; color: #475569;">Amount</th>
          </tr>
        </thead>
        <tbody>
          <% workOrder.lineItems.forEach(function(item) { %>
          <tr>
            <td style="padding: 8px 10px; border-bottom: 1px solid #e2e8f0;"><%= item.description %></td>
            <td style="padding: 8px 10px; text-align: right; border-bottom: 1px solid #e2e8f0;"><%= item.quantity %></td>
            <td style="padding: 8px 10px; text-align: right; border-bottom: 1px solid #e2e8f0;">$<%= (item.unitPriceInCents / 100).toFixed(2) %></td>
            <td style="padding: 8px 10px; text-align: right; border-bottom: 1px solid #e2e8f0; font-weight: 600;">$<%= (item.amountInCents / 100).toFixed(2) %></td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </td>
  </tr>
  <% } %>

  <tr>
    <td class="content">
      <p style="font-size: 14px; color: #64748b;">
        Log in to the portal to approve or reject this work order before the vendor proceeds.
      </p>
    </td>
  </tr>
</table>
