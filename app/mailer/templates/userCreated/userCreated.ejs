<table role="presentation" width="100%">
  <tr>
    <td class="content">
      <h2>Your Account is Ready</h2>
      <p>Hi <%= firstName %>,</p>
      <p>
        Your PropertyDesk account at <strong><%= companyName %></strong> has been set up. Here's what you need to know before you log in.
      </p>

      <% if (role === ROLES.VENDOR) { %>
        <p>
          As a vendor partner, you have access to the vendor portal to receive work orders, submit invoices, and coordinate directly with the property management team.
        </p>
        <% if (vendorCompanyName) { %>
        <p>
          Your company <strong><%= vendorCompanyName %></strong> is registered in our system.
        </p>
        <% } %>
      <% } else if (role === ROLES.TENANT) { %>
        <p>
          As a resident, your portal gives you 24/7 access to submit maintenance requests, pay rent, and communicate with your property management team.
        </p>
      <% } else { %>
        <p>
          As a <strong><%= role %></strong> team member, you can manage properties, work with residents and vendors, and collaborate with your team.
        </p>
        <% if (department) { %>
        <p>
          You've been assigned to the <strong><%= department %></strong> department<% if (jobTitle) { %> as <strong><%= jobTitle %></strong><% } %>.
        </p>
        <% } %>
      <% } %>

      <% if (customMessage) { %>
      <div class="message-quote">
        "<%= customMessage %>"
      </div>
      <% } %>
    </td>
  </tr>

  <tr>
    <td class="content" style="padding-top: 0;">
      <div class="credential-box">
        <h3>Your Login Credentials</h3>
        <table role="presentation" width="100%" style="font-size: 14px;">
          <tr>
            <td style="padding: 5px 0; color: #64748b; width: 35%;">Email</td>
            <td style="padding: 5px 0; font-weight: 600;"><%= email %></td>
          </tr>
          <tr>
            <td style="padding: 5px 0; color: #64748b;">Temporary Password</td>
            <td style="padding: 5px 0;"><code><%= temporaryPassword %></code></td>
          </tr>
        </table>
        <p style="font-size: 13px; color: #64748b; margin: 12px 0 0 0;">
          For your security, please change your password immediately after your first login.
        </p>
      </div>

      <% if (expectedStartDate) { %>
      <p style="font-size: 14px; color: #64748b;">
        Your expected start date is <strong><%= new Date(expectedStartDate).toLocaleDateString() %></strong>.
      </p>
      <% } %>
    </td>
  </tr>

  <tr>
    <td class="cta">
      <%- include("../shared/html/_button", { url: loginUrl, label: "Log In to PropertyDesk" }) %>
      <p class="fallback-link">
        Button not working? Copy and paste this link into your browser:<br />
        <%= loginUrl %>
      </p>
    </td>
  </tr>
</table>
