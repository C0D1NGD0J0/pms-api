  "paymentGateways": {
    "stripe": {
      "provider": "stripe",
      "displayName": "Stripe",
      "isActive": true,
      "processingFee": {
        "percentRate": 2.9,
        "fixedFeeCents": 30,
        "description": "Card rate (2.9% + $0.30). Used for card payments and as a fallback estimate. Verify with your Stripe account dashboard."
      },
      "acssProcessingFee": {
        "percentRate": 0,
        "fixedFeeCents": 80,
        "description": "ACSS debit (Canadian bank debit / PAD) flat fee of $0.80 CAD per transaction. Much cheaper than card for large rent amounts."
      },
      "note": "processingFee applies to card payments. acssProcessingFee applies when the payment method is acss_debit. Actual fees will be fetched from Stripe Balance Transaction API after payment and updated via webhook.",
      "applicationFeeSettings": {
        "payerType": "application",
        "description": "Platform pays Stripe fees from application fee (controller.fees.payer = 'application')"
      },
      "connectSettings": {
        "accountType": "express",
        "capabilities": ["card_payments", "transfers"]
      }
    },
    "paypal": {
      "provider": "paypal",
      "displayName": "PayPal",
      "isActive": false,
      "processingFee": {
        "percentRate": 2.99,
        "fixedFeeCents": 49,
        "description": "Standard PayPal rate (2.99% + $0.49). Verify with your PayPal account."
      },
      "note": "This is an estimate. Actual fees may vary based on transaction type."
    }
  },

