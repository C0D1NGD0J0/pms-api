{
  "$schema": "./platform.config.schema.json",
  "version": "1.0.0",
  "lastUpdated": "2026-05-28",
  "description": "Platform configuration for subscription plans and payment gateway settings",

  "achPercentRate": 1.75,

  "manualPaymentRecords": {
    "freeQuotaPerPeriod": 25,
    "overageFeeCents": 95
