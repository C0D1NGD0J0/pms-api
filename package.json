{
  "name": "property-management-system",
  "version": "0.0.1",
  "description": "Property management system that helps landlord streamline rental payment, property maintenance etc...",
  "main": "server.js",
  "engines": {
    "node": ">=22.0.0 <23.0.0"
  },
  "scripts": {
    "build": "rm -rf ./dist && tsc -p ./tsconfig.build.json && tsc-alias",
    "postbuild": "node post-build-assets.js",
    "prettier:check": "prettier --check './app/**/*.{ts,json,js}' './tests/**/*.{ts,json,js}'",
    "prettier:write": "prettier --write './app/**/*.{ts,json,js}' './tests/**/*.{ts,json,js}'",
    "lint:fix": "eslint './app/**/*.{ts,js}' './tests/**/*.{ts,js}' --fix",
    "lint": "eslint './app/**/*.{ts,js}' './tests/**/*.{ts,js}'",
    "prepare": "husky",
    "dev": "npm run killdev && concurrently \"npm run dev:api\" \"npm run dev:worker\"",
    "killdev": "pkill -f 'nodemon.*pms-api' 2>/dev/null; pkill -f 'ts-node/register server\\.ts' 2>/dev/null; pkill -f 'ts-node/register worker_process\\.ts' 2>/dev/null; rm -f .pids/api.pid .pids/worker.pid; true",
    "dev:api": "nodemon --exec 'node --inspect=9229 --expose-gc -r ts-node/register' server.ts",
    "dev:worker": "nodemon --exec 'node --inspect=9230 --expose-gc -r ts-node/register' worker_process.ts",
    "start:api": "node dist/server.js",
    "start:worker": "node dist/worker_process.js",
    "start": "node dist/server.js",
    "test": "cross-env JEST_USE_DB=false NODE_ENV=test jest",
    "test:watch": "cross-env NODE_ENV=test jest --watch",
    "test:coverage": "cross-env NODE_ENV=test jest --coverage",
    "test:unit": "cross-env NODE_ENV=test JEST_USE_DB=false jest --testPathPattern=\"tests/unit/${npm_config_path:-}\"",
    "test:integration": "cross-env NODE_ENV=test JEST_USE_DB=true jest --config test.config.integration.ts",
    "test:integration:watch": "cross-env NODE_ENV=test JEST_USE_DB=true jest --config test.config.integration.ts --watch",
    "migrate": "ts-node -r tsconfig-paths/register"
  },
  "keywords": [
    "property-management-system",
    "nodejs",
    "mongodb",
    "stripe"
  ],
  "author": "C0D1NGD0J0",
  "license": "ISC",
